# Copy to .env and adjust. Used by FastAPI auth + database/check_connection.py.
# The API loads this file on startup (python-dotenv). Any of these keys work:
#   DATABASE_URL, POSTGRES_URL, or DB_URL
#
# Local Postgres:
# DATABASE_URL=postgresql://shiksha_app:PASSWORD@localhost:5432/shikshasetu
#
# Supabase (Project Settings → Database → URI):
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# FastAPI dev port (default 8000). If you get "Address already in use", change API_PORT and API_ORIGIN.
# API_PORT=8000

# Where Next.js should proxy /shiksha-api/* (must match the running API). If you change API_PORT:
# API_ORIGIN=http://127.0.0.1:8010

# Next.js browser → API: default is same-origin /shiksha-api (rewritten to API_ORIGIN). Override for production:
# NEXT_PUBLIC_API_URL=https://your-api.example.com

# Server-side fetch (SSR) when NEXT_PUBLIC_API_URL is unset:
# API_SSR_ORIGIN=http://127.0.0.1:8000

# ── LLM for FastAPI /solve + /chat (OpenAI Python SDK, OpenAI-compatible hosts) — required for real answers
# Put this file in the project root (same folder as server_main.py). The API loads it on startup.
#
# OpenAI (default base URL is api.openai.com):
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
#
# Groq (fast, free tier; base URL is set automatically):
# GROQ_API_KEY=gsk_...
# OPENAI_MODEL=llama-3.1-8b-instant
#
# Grok / xAI:
# XAI_API_KEY=xai-...
# XAI_BASE_URL=https://api.x.ai/v1
# OPENAI_MODEL=grok-2-latest
#
# Any other OpenAI-compatible host:
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://your-host/v1
#
# GROQ_API_KEY=