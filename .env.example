# Copy to `.env` in the project root. Restart `npm run dev` after changes.

# ── Postgres (FastAPI: server_auth / server_db — python-dotenv) ──────────────
# DATABASE_URL, POSTGRES_URL, or DB_URL are accepted by the backend.
#
# Local:
# DATABASE_URL=postgresql://shiksha_app:PASSWORD@localhost:5432/shikshasetu
#
# Supabase (Project Settings → Database → URI):
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── Next.js (optional) ───────────────────────────────────────────────────────
# Leave unset locally: the app calls the API via same-origin rewrite `/backend-api/*` → http://127.0.0.1:8000
# Set only if the UI and API are on different hosts (e.g. Vercel + Railway):
# NEXT_PUBLIC_API_URL=https://your-api.example.com

# ── Firebase / Google sign-in (optional) ─────────────────────────────────────
# Without these, email/password login still works. With real values, "Continue with Google" works.
# Firebase Console → Project settings → Your apps → Web app config.
#
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
